{
  "name": "JesusGarciaValadez",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "nuxt-ts",
    "build": "nuxt-ts build",
    "start": "nuxt-ts start",
    "generate": "nuxt-ts generate",
    "lint:js": "eslint --ext \".js,.vue\" --ignore-path .gitignore .",
    "lint": "yarn lint:js",
    "test": "jest",
    "cypress:open": "cypress open",
    "build-css": "postcss src/css/tailwind.css -o public/css/style.css --pretty",
    "build-prod": "postcss src/css/tailwind.css -o public/css/style.css --map --env=production",
    "watch-css": "postcss src/css/tailwind.css -o public/css/style.css --watch --pretty"
  },
  "dependencies": {
    "@nuxt/content": "^1.11.1",
    "@nuxt/typescript-runtime": "^2.0.1",
    "@nuxtjs/axios": "^5.12.5",
    "@nuxtjs/pwa": "^3.3.5",
    "@tailwindcss/aspect-ratio": "^0.2.0",
    "@tailwindcss/forms": "^0.2.1",
    "@tailwindcss/typography": "^0.4.0",
    "autoprefixer": "^9.8.5",
    "core-js": "^3.8.3",
    "cssnano": "^4.1.10",
    "nuxt": "^2.14.12",
    "postcss": "^7.0.32",
    "postcss-import": "^14.0.0",
    "tailwindcss": "^2.0.3",
    "vue-fragment": "^1.5.1",
    "vue-fragment-ts": "^1.5.3"
  },
  "devDependencies": {
    "@nuxt/types": "^2.14.12",
    "@nuxt/typescript-build": "^2.0.4",
    "@nuxtjs/eslint-config-typescript": "^5.0.0",
    "@nuxtjs/eslint-module": "^3.0.2",
    "@nuxtjs/tailwindcss": "^3.4.2",
    "@vue/test-utils": "^1.1.2",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^26.6.3",
    "cypress": "^4.11.0",
    "eslint": "^7.18.0",
    "eslint-config-prettier": "^7.2.0",
    "eslint-plugin-nuxt": "^2.0.0",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-vue": "^7.5.0",
    "jest": "^26.6.3",
    "nuxt-purgecss": "^1.0.0",
    "prettier": "^2.2.1",
    "ts-jest": "^26.4.4",
    "vue-jest": "^3.0.4"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,vue}": [
      "yarn lint:js  --lint",
      "git add"
    ]
  }
}
